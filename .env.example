# Environment templates for Household Score App

# App mode
APP_ENV=dev

# Database URLs
# Use separate DBs for dev/stg/prod.
DATABASE_URL_DEV=postgres://app_user:change_me@localhost:5432/household_score_dev
DATABASE_URL_STG=postgres://app_user:change_me@stg-db-host:5432/household_score_stg
DATABASE_URL_PROD=postgres://app_user:change_me@prod-db-host:5432/household_score_prod

# API base URL (when backend is introduced)
API_BASE_URL_DEV=http://localhost:3000
API_BASE_URL_STG=https://api-stg.example.com
API_BASE_URL_PROD=https://api.example.com

# Security / auth
JWT_ISSUER=household-score
JWT_AUDIENCE=household-score-app
JWT_SECRET=change_me_long_random_string

# Consent document version (must match server-side validation)
CONSENT_VERSION=2026-03-ja-v1

